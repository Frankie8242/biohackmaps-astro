---
interface Props {
  placeholder?: string;
}

const { placeholder = "Search venues, cities, or modalities..." } = Astro.props;
---

<div class="search-wrapper">
  <input
    type="text"
    id="search-input"
    class="search-bar"
    placeholder={placeholder}
  />
  <span class="search-icon">🔍</span>
</div>

<style>
  .search-wrapper {
    position: relative;
    width: 100%;
  }

  .search-bar {
    width: 100%;
    padding: 12px 16px 12px 40px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    transition: all 0.2s;
  }

  .search-bar:focus {
    outline: none;
    border-color: var(--accent);
    background: var(--surface2);
    box-shadow: 0 0 0 2px rgba(249, 115, 22, 0.1);
  }

  .search-bar::placeholder {
    color: var(--muted);
  }

  .search-icon {
    position: absolute;
    left: 12px;
    top: 50%;
    transform: translateY(-50%);
    pointer-events: none;
    font-size: 16px;
  }

  @media (max-width: 768px) {
    .search-bar {
      padding: 10px 14px 10px 36px;
      font-size: 13px;
    }

    .search-icon {
      font-size: 14px;
    }
  }
</style>

<script>
  // Client-side search functionality will be added
  const searchInput = document.getElementById('search-input');
  
  if (searchInput) {
    searchInput.addEventListener('input', (e) => {
      const query = (e.target as HTMLInputElement).value.toLowerCase();
      // Search logic will be implemented in pages
      console.log('Search for:', query);
    });
  }
</script>
