---
interface Props {
  title: string;
  subtitle: string;
  cta?: string;
}

const { title, subtitle, cta } = Astro.props;
---

<section class="hero">
  <div class="hero-content">
    <h1>{title}</h1>
    <p>{subtitle}</p>
    {cta && (
      <a href="/venues/" class="cta-button">
        {cta}
      </a>
    )}
  </div>
</section>

<style>
  .hero {
    background: linear-gradient(180deg, var(--black) 0%, var(--surface) 100%);
    border-bottom: 1px solid var(--border);
    padding: 5rem 2rem 4rem;
    text-align: center;
  }

  .hero-content {
    max-width: 1200px;
    margin: 0 auto;
  }

  .hero-content h1 {
    font-size: 56px;
    margin-bottom: 1rem;
    background: linear-gradient(135deg, var(--accent), var(--accent2), var(--accent3));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-content p {
    font-size: 20px;
    color: var(--muted);
    margin-bottom: 2rem;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .cta-button {
    display: inline-block;
    padding: 12px 32px;
    background: var(--accent);
    color: var(--black);
    text-decoration: none;
    border-radius: 4px;
    font-weight: 600;
    transition: all 0.2s;
    border: 2px solid var(--accent);
  }

  .cta-button:hover {
    background: transparent;
    color: var(--accent);
  }

  @media (max-width: 768px) {
    .hero {
      padding: 3rem 1rem;
    }

    .hero-content h1 {
      font-size: 36px;
    }

    .hero-content p {
      font-size: 16px;
    }
  }

  @media (max-width: 480px) {
    .hero {
      padding: 2rem 1rem;
    }

    .hero-content h1 {
      font-size: 28px;
    }

    .hero-content p {
      font-size: 14px;
    }
  }
</style>
