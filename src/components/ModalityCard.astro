---
import type { Modality } from '../types/venue';

interface Props {
  modality: Modality;
}

const { modality } = Astro.props;
---

<a href={`/modalities/${modality.slug}`} class="modality-card">
  <div class="icon">{modality.icon}</div>
  <h3>{modality.name}</h3>
  <p>{modality.description}</p>
  <div class="benefits">
    {modality.benefits.slice(0, 2).map(benefit => (
      <span class="benefit-tag">{benefit}</span>
    ))}
  </div>
</a>

<style>
  .modality-card {
    display: block;
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 1.5rem;
    border-radius: 8px;
    text-decoration: none;
    color: inherit;
    transition: all 0.3s;
    text-align: center;
  }

  .modality-card:hover {
    background: var(--surface2);
    border-color: var(--accent2);
    transform: translateY(-4px);
  }

  .icon {
    font-size: 48px;
    margin-bottom: 1rem;
  }

  .modality-card h3 {
    font-size: 18px;
    margin-bottom: 0.5rem;
  }

  .modality-card p {
    font-size: 13px;
    color: var(--muted);
    margin-bottom: 1rem;
    line-height: 1.5;
  }

  .benefits {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
  }

  .benefit-tag {
    display: inline-block;
    background: rgba(168, 85, 247, 0.1);
    color: var(--accent3);
    padding: 4px 8px;
    border-radius: 4px;
    font-size: 11px;
    font-weight: 500;
  }

  @media (max-width: 480px) {
    .modality-card {
      padding: 1rem;
    }

    .icon {
      font-size: 36px;
      margin-bottom: 0.75rem;
    }

    .modality-card h3 {
      font-size: 14px;
    }

    .modality-card p {
      font-size: 12px;
    }
  }
</style>
