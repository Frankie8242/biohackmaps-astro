<footer class="footer">
  <div class="footer-container">
    <div class="footer-section">
      <h4>BiohackMap</h4>
      <p>The world's most complete directory of biohacking venues worldwide.</p>
    </div>

    <div class="footer-section">
      <h5>Explore</h5>
      <ul>
        <li><a href="/venues/">All Venues</a></li>
        <li><a href="/science/">Science</a></li>
        <li><a href="/for-business/">For Business</a></li>
      </ul>
    </div>

    <div class="footer-section">
      <h5>Legal</h5>
      <ul>
        <li><a href="#">Privacy Policy</a></li>
        <li><a href="#">Terms of Service</a></li>
        <li><a href="#">Contact</a></li>
      </ul>
    </div>

    <div class="footer-section">
      <h5>Connect</h5>
      <ul>
        <li><a href="#">Twitter</a></li>
        <li><a href="#">Instagram</a></li>
        <li><a href="#">Email</a></li>
      </ul>
    </div>
  </div>

  <div class="footer-bottom">
    <p>&copy; 2026 BiohackMap. All rights reserved.</p>
  </div>
</footer>

<style>
  .footer {
    background: var(--surface);
    border-top: 1px solid var(--border);
    color: var(--text);
    padding: 3rem 0;
    margin-top: 4rem;
  }

  .footer-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2rem;
    margin-bottom: 2rem;
  }

  .footer-section h4 {
    font-size: 18px;
    margin-bottom: 0.5rem;
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .footer-section h5 {
    font-size: 14px;
    font-weight: 600;
    margin-bottom: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .footer-section p {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.6;
  }

  .footer-section ul {
    list-style: none;
    padding: 0;
  }

  .footer-section li {
    margin-bottom: 0.5rem;
  }

  .footer-section a {
    color: var(--muted);
    text-decoration: none;
    font-size: 13px;
    transition: color 0.2s;
  }

  .footer-section a:hover {
    color: var(--accent);
  }

  .footer-bottom {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
    border-top: 1px solid var(--border);
    text-align: center;
    color: var(--muted);
    font-size: 12px;
  }

  @media (max-width: 768px) {
    .footer-container {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
      padding: 0 1rem;
    }

    .footer-section h4 {
      font-size: 14px;
    }

    .footer-section h5 {
      font-size: 12px;
    }
  }

  @media (max-width: 480px) {
    .footer-container {
      grid-template-columns: 1fr;
      gap: 1rem;
      padding: 0 1rem;
    }

    .footer {
      padding: 2rem 0;
    }

    .footer-bottom {
      padding: 1.5rem;
    }
  }
</style>
