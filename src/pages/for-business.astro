---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="For Business">
  <Nav current="business" />

  <section class="hero">
    <div class="hero-content">
      <h1>For Business Owners</h1>
      <p>Get your biohacking venue on BiohackMap</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="content-wrapper">
        <div class="benefits">
          <h2>Why List Your Venue?</h2>
          
          <div class="benefit-item">
            <h3>📍 Reach Local Customers</h3>
            <p>Appear in searches for "sauna near me", "cryotherapy in [city]", and other high-intent searches</p>
          </div>

          <div class="benefit-item">
            <h3>⭐ Build Social Proof</h3>
            <p>Showcase verified reviews, ratings, and customer testimonials in one central location</p>
          </div>

          <div class="benefit-item">
            <h3>💰 Drive Revenue</h3>
            <p>Free basic listing. Upgrade to Featured ($99-199/month) to rank at the top of searches</p>
          </div>

          <div class="benefit-item">
            <h3>🔍 SEO Boost</h3>
            <p>Every venue gets its own optimized page that ranks on Google. More pages = more visibility</p>
          </div>

          <div class="benefit-item">
            <h3>🏆 Verification Badge</h3>
            <p>Stand out with a verified badge that builds trust with customers</p>
          </div>

          <div class="benefit-item">
            <h3>📊 Analytics</h3>
            <p>Track views, clicks, and inquiries from BiohackMap visitors</p>
          </div>
        </div>

        <div class="pricing">
          <h2>Pricing</h2>

          <div class="pricing-card">
            <h3>Free Listing</h3>
            <p class="price">$0<span>/month</span></p>
            <ul class="features">
              <li>✓ Basic venue information</li>
              <li>✓ Location & modalities</li>
              <li>✓ Hours & contact info</li>
              <li>✓ Venue page on BiohackMap</li>
            </ul>
            <button class="button button-outline">Get Started</button>
          </div>

          <div class="pricing-card featured">
            <p class="badge-top">POPULAR</p>
            <h3>Featured Listing</h3>
            <p class="price">$99<span>/month</span></p>
            <ul class="features">
              <li>✓ Everything in Free</li>
              <li>✓ Featured on city pages</li>
              <li>✓ Top of search results</li>
              <li>✓ Premium badge</li>
              <li>✓ Photo gallery</li>
              <li>✓ Booking link integration</li>
            </ul>
            <button class="button">Upgrade to Featured</button>
          </div>

          <div class="pricing-card">
            <h3>Premium Profile</h3>
            <p class="price">$199<span>/month</span></p>
            <ul class="features">
              <li>✓ Everything in Featured</li>
              <li>✓ Professional photos</li>
              <li>✓ Team member profiles</li>
              <li>✓ Analytics dashboard</li>
              <li>✓ Priority support</li>
              <li>✓ Custom branding</li>
            </ul>
            <button class="button button-outline">Learn More</button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-dark">
    <div class="container">
      <h2>List Your Venue Today</h2>
      <p class="subtitle">Join hundreds of biohacking venues getting discovered by health-conscious customers worldwide</p>

      <form class="signup-form">
        <div class="form-group">
          <label for="name">Venue Name *</label>
          <input type="text" id="name" name="name" required />
        </div>

        <div class="form-group">
          <label for="email">Email *</label>
          <input type="email" id="email" name="email" required />
        </div>

        <div class="form-group">
          <label for="city">City *</label>
          <input type="text" id="city" name="city" required />
        </div>

        <div class="form-group">
          <label for="website">Website</label>
          <input type="url" id="website" name="website" />
        </div>

        <div class="form-group">
          <label for="modalities">Which modalities do you offer? *</label>
          <div class="checkbox-group">
            <label><input type="checkbox" name="modality" value="infrared-sauna" /> Infrared Sauna</label>
            <label><input type="checkbox" name="modality" value="cryotherapy" /> Cryotherapy</label>
            <label><input type="checkbox" name="modality" value="float-tank" /> Float Tank</label>
            <label><input type="checkbox" name="modality" value="red-light-therapy" /> Red Light Therapy</label>
            <label><input type="checkbox" name="modality" value="cold-plunge" /> Cold Plunge</label>
            <label><input type="checkbox" name="modality" value="trt-clinic" /> TRT Clinic</label>
          </div>
        </div>

        <button type="submit" class="button">Submit Listing</button>
      </form>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .hero {
    background: linear-gradient(135deg, var(--surface) 0%, var(--surface2) 100%);
    border-bottom: 1px solid var(--border);
    padding: 3rem 2rem;
    text-align: center;
  }

  .hero-content {
    max-width: 1200px;
    margin: 0 auto;
  }

  .hero-content h1 {
    font-size: 48px;
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 0.5rem;
  }

  .hero-content p {
    color: var(--muted);
    font-size: 16px;
  }

  .section {
    padding: 3rem 2rem;
  }

  .section-dark {
    background: var(--surface);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .content-wrapper {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
  }

  .benefits h2,
  .pricing h2 {
    font-size: 32px;
    margin-bottom: 2rem;
  }

  .benefit-item {
    margin-bottom: 2rem;
  }

  .benefit-item h3 {
    font-size: 18px;
    margin-bottom: 0.5rem;
  }

  .benefit-item p {
    color: var(--muted);
    line-height: 1.6;
  }

  .pricing {
    display: flex;
    flex-direction: column;
  }

  .pricing-card {
    background: var(--surface2);
    border: 1px solid var(--border);
    padding: 2rem;
    border-radius: 8px;
    margin-bottom: 1.5rem;
    position: relative;
    transition: all 0.3s;
  }

  .pricing-card.featured {
    border-color: var(--accent);
    background: linear-gradient(135deg, rgba(249, 115, 22, 0.05), rgba(6, 182, 212, 0.05));
    transform: scale(1.05);
  }

  .badge-top {
    position: absolute;
    top: -12px;
    right: 1rem;
    background: var(--accent);
    color: var(--black);
    padding: 4px 12px;
    border-radius: 4px;
    font-size: 11px;
    font-weight: 700;
  }

  .pricing-card h3 {
    font-size: 20px;
    margin-bottom: 0.5rem;
  }

  .price {
    font-size: 32px;
    font-weight: bold;
    color: var(--accent);
    margin-bottom: 1rem;
  }

  .price span {
    font-size: 14px;
    color: var(--muted);
  }

  .features {
    list-style: none;
    padding: 0;
    margin-bottom: 1.5rem;
  }

  .features li {
    padding: 0.5rem 0;
    color: var(--muted);
    font-size: 14px;
  }

  .button {
    padding: 12px 24px;
    background: var(--accent);
    color: var(--black);
    border: none;
    border-radius: 4px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
    width: 100%;
  }

  .button:hover {
    background: var(--accent2);
  }

  .button-outline {
    background: transparent;
    color: var(--accent);
    border: 2px solid var(--accent);
  }

  .button-outline:hover {
    background: var(--accent);
    color: var(--black);
  }

  .section:nth-of-type(3) h2 {
    font-size: 40px;
    text-align: center;
    margin-bottom: 0.5rem;
  }

  .subtitle {
    text-align: center;
    color: var(--muted);
    font-size: 16px;
    margin-bottom: 2rem;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .signup-form {
    max-width: 500px;
    margin: 0 auto;
  }

  .form-group {
    margin-bottom: 1.5rem;
  }

  .form-group label {
    display: block;
    font-weight: 500;
    margin-bottom: 0.5rem;
    font-size: 14px;
  }

  .form-group input[type="text"],
  .form-group input[type="email"],
  .form-group input[type="url"] {
    width: 100%;
    padding: 10px 12px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    transition: border-color 0.2s;
  }

  .form-group input:focus {
    outline: none;
    border-color: var(--accent);
  }

  .checkbox-group {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }

  .checkbox-group label {
    display: flex;
    align-items: center;
    font-weight: normal;
    margin-bottom: 0;
  }

  .checkbox-group input[type="checkbox"] {
    margin-right: 0.5rem;
    cursor: pointer;
    accent-color: var(--accent);
  }

  .signup-form .button {
    margin-top: 1rem;
  }

  @media (max-width: 768px) {
    .hero {
      padding: 2rem 1rem;
    }

    .hero-content h1 {
      font-size: 32px;
    }

    .section {
      padding: 2rem 1rem;
    }

    .content-wrapper {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .pricing-card.featured {
      transform: scale(1);
    }

    .checkbox-group {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 480px) {
    .section {
      padding: 1.5rem 1rem;
    }

    .hero-content h1 {
      font-size: 24px;
    }

    .pricing-card {
      padding: 1.5rem;
    }
  }
</style>
