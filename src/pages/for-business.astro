---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="For Business">
  <Nav current="business" />

  <section class="hero">
    <div class="hero-content">
      <h1>For Business Owners</h1>
      <p>Get your biohacking venue on BiohackMap</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="content-wrapper">
        <div class="benefits">
          <h2>Why List Your Venue?</h2>
          
          <div class="benefit-item">
            <h3>📍 Reach Local Customers</h3>
            <p>Appear in searches for "sauna near me", "cryotherapy in [city]", and other high-intent searches</p>
          </div>

          <div class="benefit-item">
            <h3>⭐ Build Social Proof</h3>
            <p>Showcase verified reviews, ratings, and customer testimonials in one central location</p>
          </div>

          <div class="benefit-item">
            <h3>💰 Drive Revenue</h3>
            <p>Even 2–3 new clients a month from BiohackMaps pays for itself. Premium venues rank first in every city and modality search.</p>
          </div>

          <div class="benefit-item">
            <h3>🔍 SEO Boost</h3>
            <p>Every venue gets its own optimized page that ranks on Google. More pages = more visibility</p>
          </div>

          <div class="benefit-item">
            <h3>🏆 Verification Badge</h3>
            <p>Stand out with a verified badge that builds trust with customers</p>
          </div>

          <div class="benefit-item">
            <h3>📊 Analytics</h3>
            <p>Track views, clicks, and inquiries from BiohackMap visitors</p>
          </div>
        </div>

        <div class="pricing">
          <h2>Pricing</h2>

          <div class="pricing-card">
            <h3>Free Listing</h3>
            <p class="price">$0<span>/month</span></p>
            <ul class="features">
              <li>✓ Basic venue information</li>
              <li>✓ Location & modalities</li>
              <li>✓ Hours & contact info</li>
              <li>✓ "Listed" badge on your venue card</li>
            </ul>
            <a href="#listing-form" class="button button-outline">Get Listed</a>
          </div>

          <div class="pricing-card featured">
            <h3>Premium Verified</h3>
            <p class="price">$49<span>/month</span></p>
            <ul class="features">
              <li>✓ Everything in Free</li>
              <li>✓ Gold ⭐ Verified badge — builds trust instantly</li>
              <li>✓ Rank #1 in city + modality search</li>
              <li>✓ Featured on homepage (2,500+ monthly visitors)</li>
              <li>✓ Monthly performance report (views & clicks)</li>
              <li>✓ Priority support from the founders</li>
            </ul>
            <script async src="https://js.stripe.com/v3/buy-button.js"></script>
            <stripe-buy-button
              buy-button-id="buy_btn_1TGXx3KAU2Dgyxl4wXcw2vS7"
              publishable-key="pk_live_51TGW09KAU2Dgyxl4QPsob7eNaEq7B22g0KtIyFjnaeymIP5y4dJKGzTMDax3lPyhfL7Hq9wZQ3W6aDfadqY7Rndj00acXXzgN1"
            ></stripe-buy-button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section sponsor-offer">
    <div class="container">
      <div class="sponsor-offer-inner">
        <div class="sponsor-offer-text">
          <p class="sponsor-eyebrow">Site Sponsorship</p>
          <h2>Become a Major Sponsor</h2>
          <p>Get your brand in front of thousands of health-conscious biohackers every month. Your logo, tagline, and CTA featured prominently on the BiohackMaps homepage — just like SaunaMind.</p>
          <ul class="sponsor-perks">
            <li>🏠 Full-width branded section on the homepage</li>
            <li>🔗 Direct link with your UTM tracking</li>
            <li>📣 Your tagline & call-to-action button</li>
            <li>🌍 Seen by visitors across 35+ cities</li>
            <li>📊 Monthly traffic report</li>
            <li>🤝 "Major Sponsor" badge — only 1 slot available</li>
          </ul>
          <a href="mailto:support@biohackmaps.com?subject=Site Sponsorship Enquiry" class="button">Enquire About Sponsorship →</a>
        </div>
        <div class="sponsor-offer-preview">
          <p class="preview-label">↓ Live example — what your slot looks like on the homepage</p>
          <div class="preview-card">
            <span class="preview-pill">Major Sponsor</span>
            <div class="preview-brand">
              <div class="preview-logo-box">⚡</div>
              <span class="preview-name">YOUR BRAND</span>
            </div>
            <p class="preview-tagline">YOUR SLOGAN. <span>HERE.</span></p>
            <p class="preview-desc">Your product or service described to thousands of health-conscious biohackers every month across 35+ cities.</p>
            <a class="preview-btn">Get Early Access →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-dark" id="listing-form">
    <div class="container">
      <h2>List Your Venue Today</h2>
      <p class="subtitle">Join hundreds of biohacking venues getting discovered by health-conscious customers worldwide</p>

      <form class="signup-form" name="venue-listing" method="POST" netlify action="/success/">
        <input type="hidden" name="form-name" value="venue-listing" />

        <div class="form-group">
          <label for="name">Venue Name *</label>
          <input type="text" id="name" name="name" required />
        </div>

        <div class="form-group">
          <label for="email">Email *</label>
          <input type="email" id="email" name="email" required />
        </div>

        <div class="form-group">
          <label for="city">City *</label>
          <input type="text" id="city" name="city" required />
        </div>

        <div class="form-group">
          <label for="website">Website</label>
          <input type="url" id="website" name="website" />
        </div>

        <div class="form-group">
          <label for="modalities">Which modalities do you offer? *</label>
          <div class="checkbox-group">
            <label><input type="checkbox" name="modality" value="infrared-sauna" /> Infrared Sauna</label>
            <label><input type="checkbox" name="modality" value="cryotherapy" /> Cryotherapy</label>
            <label><input type="checkbox" name="modality" value="float-tank" /> Float Tank</label>
            <label><input type="checkbox" name="modality" value="red-light-therapy" /> Red Light Therapy</label>
            <label><input type="checkbox" name="modality" value="cold-plunge" /> Cold Plunge</label>
            <label><input type="checkbox" name="modality" value="trt-clinic" /> TRT Clinic</label>
          </div>
        </div>

        <button type="submit" class="button">Submit Listing</button>
      </form>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .hero {
    background: linear-gradient(135deg, var(--surface) 0%, var(--surface2) 100%);
    border-bottom: 1px solid var(--border);
    padding: 3rem 2rem;
    text-align: center;
  }

  .hero-content {
    max-width: 1200px;
    margin: 0 auto;
  }

  .hero-content h1 {
    font-size: 48px;
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 0.5rem;
  }

  .hero-content p {
    color: var(--muted);
    font-size: 16px;
  }

  .section {
    padding: 3rem 2rem;
  }

  .section-dark {
    background: var(--surface);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .content-wrapper {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
  }

  .benefits h2,
  .pricing h2 {
    font-size: 32px;
    margin-bottom: 2rem;
  }

  .benefit-item {
    margin-bottom: 2rem;
  }

  .benefit-item h3 {
    font-size: 18px;
    margin-bottom: 0.5rem;
  }

  .benefit-item p {
    color: var(--muted);
    line-height: 1.6;
  }

  .pricing {
    display: flex;
    flex-direction: column;
  }

  .pricing-card {
    background: var(--surface2);
    border: 1px solid var(--border);
    padding: 2rem;
    border-radius: 8px;
    margin-bottom: 1.5rem;
    position: relative;
    transition: all 0.3s;
  }

  .pricing-card.featured {
    border-color: var(--accent);
    background: linear-gradient(135deg, rgba(249, 115, 22, 0.05), rgba(6, 182, 212, 0.05));
    transform: scale(1.05);
  }

  .social-proof {
    font-size: 12px;
    color: var(--muted);
    text-align: center;
    margin-top: 0.75rem;
  }
  .social-proof strong { color: #fbbf24; }

  .badge-top {
    position: absolute;
    top: -12px;
    right: 1rem;
    background: var(--accent);
    color: var(--black);
    padding: 4px 12px;
    border-radius: 4px;
    font-size: 11px;
    font-weight: 700;
  }

  .pricing-card h3 {
    font-size: 20px;
    margin-bottom: 0.5rem;
  }

  .price {
    font-size: 32px;
    font-weight: bold;
    color: var(--accent);
    margin-bottom: 1rem;
  }

  .price span {
    font-size: 14px;
    color: var(--muted);
  }

  .features {
    list-style: none;
    padding: 0;
    margin-bottom: 1.5rem;
  }

  .features li {
    padding: 0.5rem 0;
    color: var(--muted);
    font-size: 14px;
  }

  .button {
    padding: 12px 24px;
    background: var(--accent);
    color: var(--black);
    border: none;
    border-radius: 4px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
    width: 100%;
  }

  .button:hover {
    background: var(--accent2);
  }

  .button-outline {
    background: transparent;
    color: var(--accent);
    border: 2px solid var(--accent);
  }

  .button-outline:hover {
    background: var(--accent);
    color: var(--black);
  }

  .section:nth-of-type(3) h2 {
    font-size: 40px;
    text-align: center;
    margin-bottom: 0.5rem;
  }

  .subtitle {
    text-align: center;
    color: var(--muted);
    font-size: 16px;
    margin-bottom: 2rem;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .signup-form {
    max-width: 500px;
    margin: 0 auto;
  }

  .form-group {
    margin-bottom: 1.5rem;
  }

  .form-group label {
    display: block;
    font-weight: 500;
    margin-bottom: 0.5rem;
    font-size: 14px;
  }

  .form-group input[type="text"],
  .form-group input[type="email"],
  .form-group input[type="url"] {
    width: 100%;
    padding: 10px 12px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    transition: border-color 0.2s;
  }

  .form-group input:focus {
    outline: none;
    border-color: var(--accent);
  }

  .checkbox-group {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }

  .checkbox-group label {
    display: flex;
    align-items: center;
    font-weight: normal;
    margin-bottom: 0;
  }

  .checkbox-group input[type="checkbox"] {
    margin-right: 0.5rem;
    cursor: pointer;
    accent-color: var(--accent);
  }

  .signup-form .button {
    margin-top: 1rem;
  }

  @media (max-width: 768px) {
    .hero {
      padding: 2rem 1rem;
    }

    .hero-content h1 {
      font-size: 32px;
    }

    .section {
      padding: 2rem 1rem;
    }

    .content-wrapper {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .pricing-card.featured {
      transform: scale(1);
    }

    .checkbox-group {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 480px) {
    .section {
      padding: 1.5rem 1rem;
    }

    .hero-content h1 {
      font-size: 24px;
    }

    .pricing-card {
      padding: 1.5rem;
    }
  }
  /* Sponsorship section */
  .sponsor-offer {
    background: radial-gradient(ellipse at 60% 50%, rgba(180,100,56,0.1) 0%, transparent 70%);
    border-bottom: 1px solid var(--border);
  }

  .sponsor-offer-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    max-width: 1100px;
    margin: 0 auto;
  }

  .sponsor-eyebrow {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #b46438;
    margin-bottom: 1rem;
  }

  .sponsor-offer-text h2 {
    font-size: 36px;
    margin-bottom: 1rem;
    text-align: left;
  }

  .sponsor-offer-text > p {
    color: var(--muted);
    font-size: 16px;
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  .sponsor-perks {
    list-style: none;
    padding: 0;
    margin-bottom: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .sponsor-perks li {
    font-size: 15px;
    color: #bbb;
  }

  .sponsor-offer-preview {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .preview-label {
    font-size: 12px;
    color: var(--muted);
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  .preview-card {
    background: radial-gradient(ellipse at center, rgba(180,100,56,0.15) 0%, var(--black) 70%);
    border-top: 1px solid #2a1a0e;
    border-bottom: 1px solid #2a1a0e;
    border-left: none;
    border-right: none;
    border-radius: 12px;
    padding: 2.5rem 2rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .preview-pill {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #b46438;
    border: 1px solid #3a2a1e;
    padding: 3px 12px;
    border-radius: 100px;
  }

  .preview-brand {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .preview-logo-box {
    font-size: 40px;
    filter: drop-shadow(0 0 12px rgba(232,149,106,0.5));
  }

  .preview-name {
    font-family: 'Outfit', sans-serif;
    font-weight: 900;
    font-size: 36px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text);
  }

  .preview-tagline {
    font-family: 'Outfit', sans-serif;
    font-weight: 900;
    font-size: 14px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--text);
  }
  .preview-tagline span { color: #E8956A; }

  .preview-desc {
    font-size: 13px;
    color: #666;
    max-width: 280px;
    line-height: 1.6;
  }

  .preview-btn {
    display: inline-block;
    background: #b46438;
    color: #fff;
    padding: 10px 24px;
    border-radius: 100px;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-decoration: none;
  }

  @media (max-width: 768px) {
    .sponsor-offer-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .sponsor-offer-text h2 { font-size: 26px; }
  }

</style>
