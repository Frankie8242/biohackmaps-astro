---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import HeroSection from '../components/HeroSection.astro';
import ModalityCard from '../components/ModalityCard.astro';
import VenueCard from '../components/VenueCard.astro';
import Footer from '../components/Footer.astro';
import { getAllModalities } from '../data/modalities';
import { getAllVenues, getUniqueCities } from '../data/venues';
import { generateOrganizationSchema } from '../lib/schema';

const toSlug = (s: string) => s.toLowerCase().replace(/\s+/g, '-');

const modalities = getAllModalities();
const allVenues = getAllVenues();
const featuredVenues = allVenues.filter(v => v.featured).slice(0, 6);
const orgSchema = generateOrganizationSchema(Astro.url.origin);

// Find any venue pinned via pinnedUntil that is still active as of build time
const today = new Date().toISOString().slice(0, 10);
const pinnedVenue = allVenues.find(v => v.pinnedUntil && v.pinnedUntil >= today) ?? null;
// Exclude the pinned venue from the regular grid to avoid duplication
const gridVenues = pinnedVenue ? allVenues.filter(v => v.slug !== pinnedVenue.slug) : allVenues;
const uniqueCities = getUniqueCities();
const uniqueCityCount = uniqueCities.length;

// Top cities by venue count for "Browse by City" section
const topCities = uniqueCities
  .map(c => ({
    name: c,
    slug: toSlug(c),
    count: allVenues.filter(v => v.city === c).length,
    country: allVenues.find(v => v.city === c)?.country ?? '',
  }))
  .sort((a, b) => b.count - a.count)
  .slice(0, 16);
---

<Layout title="Home">
  <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
  <Nav current="home" />
  
  <HeroSection 
    title="BiohackMap"
    subtitle="The world's most complete directory of biohacking venues worldwide."
    cta="Explore Venues"
  />

  <!-- Social proof stats bar -->
  <div class="stats-bar">
    <div class="stats-inner">
      <div class="stat"><span class="stat-num">{allVenues.length}</span><span class="stat-label">Verified Venues</span></div>
      <div class="stat-sep">·</div>
      <div class="stat"><span class="stat-num">{uniqueCityCount}</span><span class="stat-label">Cities</span></div>
      <div class="stat-sep">·</div>
      <div class="stat"><span class="stat-num">{modalities.length}</span><span class="stat-label">Modalities</span></div>
      <div class="stat-sep">·</div>
      <div class="stat"><span class="stat-num">4.8★</span><span class="stat-label">Avg Rating</span></div>
    </div>
  </div>

  {pinnedVenue && (
    <section class="spotlight-section">
      <div class="spotlight-glow"></div>
      <div class="container">
        <div class="spotlight-eyebrow">
          <span class="spotlight-dot"></span>
          New Listing · Featured This Week
        </div>
        <div class="spotlight-layout">
          <div class="spotlight-info">
            <h2 class="spotlight-name">{pinnedVenue.name}</h2>
            <p class="spotlight-location">📍 {pinnedVenue.city}, {pinnedVenue.country}</p>
            <p class="spotlight-desc">{pinnedVenue.description}</p>
            <a href={`/venues/${pinnedVenue.slug}`} class="spotlight-cta">View Venue →</a>
          </div>
          <div class="spotlight-card">
            <VenueCard venue={pinnedVenue} newListing={true} />
          </div>
        </div>
      </div>
    </section>
  )}

  <section class="section">
    <div class="container">
      <h2>Browse Modalities</h2>
      <p class="section-subtitle">Discover the science of self-optimization</p>

      <div class="modality-grid">
        {modalities.map(mod => (
          <ModalityCard modality={mod} />
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>Browse by City</h2>
      <p class="section-subtitle">Find biohacking venues in {uniqueCityCount} cities worldwide</p>
      <div class="city-grid">
        {topCities.map(c => (
          <a href={`/cities/${c.slug}`} class="city-card">
            <span class="city-name">{c.name}</span>
            <span class="city-meta">{c.count} venues · {c.country}</span>
          </a>
        ))}
      </div>
      <div class="cta-center">
        <a href="/venues/" class="button button-outline">View All Cities →</a>
      </div>
    </div>
  </section>

  {(featuredVenues.length > 0 || gridVenues.some(v => v.featured)) && (
    <section class="section section-dark">
      <div class="container">
        <h2 id="venues-heading">Featured Venues</h2>
        <p class="section-subtitle" id="venues-subtitle">Hand-picked biohacking destinations</p>

        <div class="venue-grid" id="venue-grid">
          {gridVenues.map(venue => (
            <div class="venue-wrapper" data-city={venue.city.toLowerCase()} data-featured={venue.featured} style="display:none">
              <VenueCard venue={venue} />
            </div>
          ))}
        </div>

        <div class="cta-center">
          <a href="/venues/" class="button button-outline">View All Venues →</a>
        </div>
      </div>
    </section>
  )}

  <section class="sponsor-section">
    <div class="sponsor-inner">
      <div class="sponsor-eyebrow">Major Sponsor</div>
      <a href="https://www.sauna-mind.com/?utm_source=biohackmaps&utm_medium=referral&utm_campaign=sponsor" target="_blank" rel="noopener noreferrer" class="sponsor-brand">
        <img src="/sauna-mind-logo.png" alt="SaunaMind logo" class="sponsor-logo" />
      </a>
      <p class="sponsor-sub">PHYSIOLOGICAL RECOVERY INTELLIGENCE</p>
      <h2 class="sponsor-headline">38.5° IS THE GOAL.<br /><span>WE GET YOU THERE.</span></h2>
      <p class="sponsor-desc">Every other sauna app runs a timer. 38.5° tracks what's actually happening inside your body — guided by peer-reviewed research.</p>
      <div class="sponsor-zones">
        <span class="zone zone-warmup">WARM-UP</span>
        <span class="zone zone-adapt">BUILDING HEAT</span>
        <span class="zone zone-hsp">PEAK HEAT</span>
        <span class="zone zone-deep">EXTREME HEAT</span>
        <span class="zone zone-caution">TIME TO COOL</span>
      </div>
      <a href="https://www.sauna-mind.com/?utm_source=biohackmaps&utm_medium=referral&utm_campaign=sponsor_cta" target="_blank" rel="noopener noreferrer" class="sponsor-appstore">
        <img src="https://developer.apple.com/assets/elements/badges/download-on-the-app-store.svg" alt="Download on the App Store" class="appstore-badge" />
      </a>
      <p class="sponsor-founding">Founding Members — $19.99/yr · locked forever</p>
    </div>
  </section>

  <Footer />
</Layout>

<script>
  (async () => {
    const wrappers = Array.from(document.querySelectorAll('.venue-wrapper'));
    const heading = document.getElementById('venues-heading');
    const subtitle = document.getElementById('venues-subtitle');

    const showVenues = (list) => {
      wrappers.forEach(w => w.style.display = 'none');
      list.slice(0, 6).forEach(w => w.style.display = 'block');
    };

    // Default: show featured venues
    const featured = wrappers.filter(w => w.dataset.featured === 'true');
    showVenues(featured);

    try {
      const res = await fetch('https://ipapi.co/json/');
      const data = await res.json();
      const city = (data.city || '').trim();
      const region = (data.region || '').trim();
      if (!city) return;

      const cityLower = city.toLowerCase();

      // Get unique cities in the directory
      const knownCities = [...new Set(wrappers.map(w => w.dataset.city))];

      // Try exact match first, then check if detected city contains a known city
      // (handles suburbs like "Surry Hills" → matches "sydney")
      let matchedCity = knownCities.find(c => c === cityLower)
        || knownCities.find(c => cityLower.includes(c))
        || knownCities.find(c => c.includes(cityLower));

      // Fallback: match by region (e.g. "New South Wales" → Sydney)
      if (!matchedCity && region) {
        const regionLower = region.toLowerCase();
        matchedCity = knownCities.find(c => regionLower.includes(c));
      }

      if (!matchedCity) return;

      const local = wrappers.filter(w => w.dataset.city === matchedCity);

      if (local.length >= 3) {
        showVenues(local);
        const displayCity = matchedCity.charAt(0).toUpperCase() + matchedCity.slice(1);
        if (heading) heading.textContent = `Venues Near You in ${displayCity}`;
        if (subtitle) subtitle.textContent = `Top-rated biohacking spots in ${displayCity}`;
      }
    } catch (_) {}
  })();
</script>

<style>
  .stats-bar {
    background: var(--surface2);
    border-bottom: 1px solid var(--border);
    padding: 1rem 2rem;
  }
  .stats-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .stat {
    display: flex;
    align-items: baseline;
    gap: 0.4rem;
  }
  .stat-num {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 22px;
    color: var(--accent);
    letter-spacing: 1px;
  }
  .stat-label {
    font-size: 13px;
    color: var(--muted);
  }
  .stat-sep {
    color: var(--border);
    font-size: 18px;
  }

  .section {
    padding: 4rem 2rem;
    border-bottom: 1px solid var(--border);
  }

  .section-dark {
    background: var(--surface);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section h2 {
    font-size: 44px;
    margin-bottom: 0.5rem;
    text-align: center;
  }

  .section-subtitle {
    text-align: center;
    color: var(--muted);
    font-size: 16px;
    margin-bottom: 2rem;
  }

  .modality-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  /* ── Spotlight / New Arrival section ── */
  .spotlight-section {
    position: relative;
    overflow: hidden;
    padding: 3rem 2rem;
    border-bottom: 1px solid rgba(168,85,247,0.25);
    background: linear-gradient(135deg, rgba(168,85,247,0.07) 0%, rgba(236,72,153,0.04) 50%, var(--bg,#0a0a0a) 100%);
  }

  .spotlight-glow {
    position: absolute;
    top: -80px;
    left: -80px;
    width: 400px;
    height: 400px;
    background: radial-gradient(ellipse, rgba(168,85,247,0.18) 0%, transparent 70%);
    pointer-events: none;
  }

  .spotlight-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #d946ef;
    margin-bottom: 1.5rem;
    border: 1px solid rgba(168,85,247,0.3);
    padding: 4px 14px;
    border-radius: 100px;
    background: rgba(168,85,247,0.06);
  }

  .spotlight-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #d946ef;
    animation: blink 1.4s ease-in-out infinite;
    flex-shrink: 0;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.25; }
  }

  .spotlight-layout {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 3rem;
    align-items: center;
  }

  .spotlight-name {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 56px;
    letter-spacing: 2px;
    margin: 0 0 0.5rem 0;
    line-height: 1;
    background: linear-gradient(135deg, #fff 40%, #d946ef 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .spotlight-location {
    color: var(--muted);
    font-size: 15px;
    margin: 0 0 1rem 0;
  }

  .spotlight-desc {
    color: var(--muted);
    font-size: 15px;
    line-height: 1.65;
    margin: 0 0 1.75rem 0;
    max-width: 480px;
  }

  .spotlight-cta {
    display: inline-block;
    background: linear-gradient(135deg, #a855f7, #ec4899);
    color: #fff;
    padding: 12px 28px;
    border-radius: 6px;
    text-decoration: none;
    font-weight: 700;
    font-size: 14px;
    letter-spacing: 0.03em;
    transition: opacity 0.2s, transform 0.2s;
    box-shadow: 0 0 24px rgba(168,85,247,0.3);
  }

  .spotlight-cta:hover {
    opacity: 0.88;
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    .spotlight-layout {
      grid-template-columns: 1fr;
    }
    .spotlight-name { font-size: 38px; }
  }

  .city-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1rem;
    margin-bottom: 2rem;
  }
  .city-card {
    display: flex; flex-direction: column; gap: 0.25rem;
    padding: 1rem 1.25rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    text-decoration: none;
    transition: all 0.2s;
  }
  .city-card:hover { border-color: var(--accent2); transform: translateY(-2px); }
  .city-name { color: var(--text); font-weight: 600; font-size: 15px; }
  .city-meta { color: var(--muted); font-size: 12px; }

  .venue-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .cta-center {
    text-align: center;
  }

  .button {
    display: inline-block;
    padding: 12px 32px;
    background: var(--accent);
    color: var(--black);
    text-decoration: none;
    border-radius: 4px;
    font-weight: 600;
    transition: all 0.2s;
    border: 2px solid var(--accent);
  }

  .button:hover {
    background: transparent;
    color: var(--accent);
  }

  .button-outline {
    background: transparent;
    color: var(--accent);
    border: 2px solid var(--accent);
  }

  .button-outline:hover {
    background: var(--accent);
    color: var(--black);
  }

  .sponsor-section {
    background: #000;
    background-image: radial-gradient(ellipse at 50% 40%, rgba(160,60,10,0.18) 0%, transparent 55%);
    border-top: 1px solid #1a1008;
    border-bottom: 1px solid #1a1008;
    padding: 0;
    overflow: hidden;
  }
  .sponsor-inner {
    max-width: 700px;
    margin: 0 auto;
    padding: 5rem 2rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .sponsor-eyebrow {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: #b46438;
    border: 1px solid #2a1a0e;
    padding: 4px 14px;
    border-radius: 100px;
  }

  .sponsor-brand { text-decoration: none; transition: opacity 0.2s; }
  .sponsor-brand:hover { opacity: 0.85; }

  .sponsor-logo {
    height: 56px;
    width: auto;
  }

  .sponsor-sub {
    font-size: 10px;
    letter-spacing: 0.35em;
    color: #555;
    margin: 0.25rem 0 0;
  }

  .sponsor-headline {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 72px;
    line-height: 1;
    color: #fff;
    margin: 0.5rem 0;
    letter-spacing: 2px;
  }
  .sponsor-headline span {
    display: block;
    color: #E8956A;
  }

  .sponsor-desc {
    font-size: 14px;
    color: #777;
    max-width: 480px;
    line-height: 1.7;
    margin: 0;
  }

  .sponsor-zones {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
    justify-content: center;
    margin: 0.5rem 0;
  }
  .zone {
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.5px;
    padding: 5px 12px;
    border-radius: 3px;
    border: none;
  }
  .zone-warmup { background: #3B8BF5; color: #fff; }
  .zone-adapt { background: #22D47A; color: #fff; }
  .zone-hsp { background: #F5A623; color: #fff; }
  .zone-deep { background: #F53B3B; color: #fff; }
  .zone-caution { background: #C41717; color: #fff; }

  .sponsor-appstore { display: inline-block; margin-top: 0.5rem; transition: opacity 0.2s; }
  .sponsor-appstore:hover { opacity: 0.8; }
  .appstore-badge { height: 44px; width: auto; }

  .sponsor-founding {
    font-size: 13px;
    color: #b46438;
    font-weight: 600;
    margin: 0;
  }

  @media (max-width: 600px) {
    .sponsor-headline { font-size: 44px; }
    .sponsor-logo { height: 44px; }
    .sponsor-inner { padding: 3.5rem 1.5rem; }
    .zone { font-size: 8px; padding: 4px 8px; }
  }

  @media (max-width: 768px) {
    .section {
      padding: 3rem 1rem;
    }

    .section h2 {
      font-size: 32px;
    }

    .modality-grid {
      grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    }

    .venue-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 480px) {
    .section {
      padding: 2rem 1rem;
    }

    .section h2 {
      font-size: 24px;
    }

    .section-subtitle {
      font-size: 14px;
    }

    .modality-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }
  }
</style>
