---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="SaunaMind — Thermal Zone Tracking">
  <Nav current="saunamind" />
  
  <section class="hero">
    <div class="hero-content">
      <h1>SaunaMind</h1>
      <p>Real-time core body temperature tracking for optimized sauna sessions</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>What is SaunaMind?</h2>
      <p class="section-subtitle">Know exactly which cellular adaptation you're triggering</p>
      
      <div class="feature-grid">
        <div class="feature-card">
          <div class="feature-icon">🌡️</div>
          <h3>Thermal Zone Mapping</h3>
          <p>SaunaMind translates your heart rate into estimated core body temperature in real time, then maps it to 5 science-backed thermal zones — so you always know which cellular process you're triggering during your session.</p>
        </div>
        
        <div class="feature-card">
          <div class="feature-icon">⌚</div>
          <h3>Device Integration</h3>
          <p>Works seamlessly with Oura Ring, Apple Watch, Polar H10, and any BLE heart rate monitor. Connect once, track everywhere.</p>
        </div>
        
        <div class="feature-card">
          <div class="feature-icon">🧬</div>
          <h3>Science-Backed</h3>
          <p>Built on validated thermal physiology research. Every zone is designed to trigger specific cellular adaptations from heat shock proteins to cardiovascular improvements.</p>
        </div>
        
        <div class="feature-card">
          <div class="feature-icon">📊</div>
          <h3>Session Analytics</h3>
          <p>Track time spent in each thermal zone, monitor progress over weeks and months, and optimize your biohacking strategy with real data.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-dark">
    <div class="container">
      <h2>The 5 Thermal Zones</h2>
      <div class="zones-grid">
        <div class="zone-card">
          <h3>Zone 1: Warm-Up</h3>
          <p><strong>Core Temp: 37–38°C</strong></p>
          <p>Cardiovascular adaptation begins. Blood vessels dilate, heart rate increases.</p>
        </div>
        
        <div class="zone-card">
          <h3>Zone 2: HSP Activation</h3>
          <p><strong>Core Temp: 38–39°C</strong></p>
          <p>Heat shock proteins (HSPs) begin expression. Cellular stress response optimizes.</p>
        </div>
        
        <div class="zone-card">
          <h3>Zone 3: Adaptation</h3>
          <p><strong>Core Temp: 39–40°C</strong></p>
          <p>Peak HSP production. Chronic disease markers decrease by 4–49% in this zone.</p>
        </div>
        
        <div class="zone-card">
          <h3>Zone 4: Deep Stress</h3>
          <p><strong>Core Temp: 40–41°C</strong></p>
          <p>Maximum cellular stress. Neurogenesis and autophagy peak. High intensity zone.</p>
        </div>
        
        <div class="zone-card">
          <h3>Zone 5: Extreme</h3>
          <p><strong>Core Temp: 41°C+</strong></p>
          <p>Extreme thermal stress. For experienced users only. Monitor closely.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>Research Foundation</h2>
      <p class="section-subtitle">Every feature is backed by peer-reviewed science</p>
      
      <div class="research-grid">
        <div class="research-card">
          <h3>+49% Heat Shock Proteins</h3>
          <p>A single 30-minute sauna session at 73°C increased HSP72 levels by 49% above baseline.</p>
          <p class="citation">Patrick & Johnson, Experimental Gerontology, 2021</p>
        </div>
        
        <div class="research-card">
          <h3>Cardiovascular Benefits</h3>
          <p>Regular sauna use reduces all-cause mortality by 27% when reaching 80–100°C for 19+ minutes per week.</p>
          <p class="citation">Laukkanen et al., JAMA Internal Medicine, 2018</p>
        </div>
        
        <div class="research-card">
          <h3>Brain Health</h3>
          <p>Heat-induced BDNF increases promote neurogenesis and cognitive function improvements.</p>
          <p class="citation">Sharma et al., Neuroscience & Biobehavioral Reviews, 2019</p>
        </div>
        
        <div class="research-card">
          <h3>Chronic Disease Marker Reduction</h3>
          <p>Markers of inflammation, cardiovascular risk, and metabolic syndrome decrease by 4–49% with regular thermal stress.</p>
          <p class="citation">Kukkonen-Harjula et al., Circulation, 2002</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section sauna-cta-section">
    <div class="container">
      <div class="cta-box">
        <h2>Coming Soon</h2>
        <p>SaunaMind is launching on TestFlight for iOS. Join the biohacking community and track your thermal journey in real time.</p>
        <a href="mailto:hello@biohackmaps.com" class="button">Request Early Access</a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .hero {
    background: linear-gradient(135deg, var(--surface) 0%, var(--surface2) 100%);
    border-bottom: 1px solid var(--border);
    padding: 4rem 2rem;
    text-align: center;
  }

  .hero-content {
    max-width: 1200px;
    margin: 0 auto;
  }

  .hero-content h1 {
    font-size: 56px;
    margin-bottom: 1rem;
    background: linear-gradient(135deg, var(--accent), var(--accent2), var(--accent3));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-content p {
    font-size: 20px;
    color: var(--muted);
    max-width: 600px;
    margin: 0 auto;
  }

  .section {
    padding: 4rem 2rem;
    border-bottom: 1px solid var(--border);
  }

  .section-dark {
    background: var(--surface);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section h2 {
    font-size: 44px;
    margin-bottom: 0.5rem;
    text-align: center;
  }

  .section-subtitle {
    text-align: center;
    color: var(--muted);
    font-size: 16px;
    margin-bottom: 2rem;
  }

  .feature-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .feature-card {
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 1.5rem;
    border-radius: 8px;
    text-align: center;
  }

  .section-dark .feature-card {
    background: var(--surface2);
  }

  .feature-icon {
    font-size: 48px;
    margin-bottom: 1rem;
  }

  .feature-card h3 {
    font-size: 18px;
    margin-bottom: 0.5rem;
  }

  .feature-card p {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.6;
  }

  .zones-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
  }

  .zone-card {
    background: var(--surface2);
    border: 1px solid var(--border);
    padding: 1.5rem;
    border-radius: 8px;
    border-left: 4px solid var(--accent2);
  }

  .zone-card h3 {
    font-size: 16px;
    margin-bottom: 0.5rem;
  }

  .zone-card p {
    font-size: 13px;
    color: var(--muted);
    margin: 0.5rem 0;
  }

  .research-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
  }

  .research-card {
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 1.5rem;
    border-radius: 8px;
  }

  .section-dark .research-card {
    background: var(--surface2);
  }

  .research-card h3 {
    font-size: 16px;
    margin-bottom: 0.75rem;
  }

  .research-card p {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.6;
  }

  .citation {
    font-size: 11px;
    color: var(--accent2);
    font-style: italic;
    margin-top: 0.75rem !important;
  }

  .sauna-cta-section {
    background: linear-gradient(135deg, #f9731633, #06b6d41a);
    border-top: 1px solid var(--border);
    border-bottom: none;
  }

  .cta-box {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 3rem 2rem;
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
  }

  .cta-box h2 {
    color: var(--accent);
    margin-bottom: 1rem;
  }

  .cta-box p {
    color: var(--muted);
    font-size: 16px;
    margin-bottom: 1.5rem;
    line-height: 1.6;
  }

  .button {
    display: inline-block;
    padding: 12px 32px;
    background: var(--accent);
    color: var(--black);
    text-decoration: none;
    border-radius: 4px;
    font-weight: 600;
    transition: all 0.2s;
    border: 2px solid var(--accent);
  }

  .button:hover {
    background: transparent;
    color: var(--accent);
  }

  @media (max-width: 768px) {
    .hero {
      padding: 3rem 1rem;
    }

    .hero-content h1 {
      font-size: 36px;
    }

    .hero-content p {
      font-size: 16px;
    }

    .section {
      padding: 3rem 1rem;
    }

    .section h2 {
      font-size: 32px;
    }

    .feature-grid {
      grid-template-columns: 1fr;
    }

    .zones-grid {
      grid-template-columns: 1fr;
    }

    .research-grid {
      grid-template-columns: 1fr;
    }

    .cta-box {
      padding: 2rem 1.5rem;
    }
  }
</style>
