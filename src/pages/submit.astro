---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const MODALITY_OPTIONS = [
  { value: 'infrared-sauna',    label: 'Infrared Sauna' },
  { value: 'cryotherapy',       label: 'Cryotherapy' },
  { value: 'float-tank',        label: 'Float Tank' },
  { value: 'red-light-therapy', label: 'Red Light Therapy' },
  { value: 'hyperbaric-oxygen', label: 'Hyperbaric Oxygen' },
  { value: 'cold-plunge',       label: 'Cold Plunge' },
  { value: 'trt-clinic',        label: 'TRT Clinic' },
  { value: 'iv-therapy',        label: 'IV Therapy' },
  { value: 'tanning',           label: 'Tanning' },
  { value: 'womens-health',     label: "Women's Health" },
];
---

<Layout
  title="Submit a Venue"
  description="Know a great biohacking venue? Submit it to BiohackMaps and help others find the best infrared saunas, cryotherapy, float tanks, and more worldwide."
>
  <Nav />

  <section class="hero">
    <div class="hero-content">
      <p class="eyebrow">Community</p>
      <h1>Submit a venue</h1>
      <p class="hero-sub">Know a great biohacking spot? Help the community discover it. Anyone can submit — it takes 30 seconds.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">

      <!-- Success state -->
      <div class="success-state" id="success-state" style="display:none;">
        <div class="success-box">
          <p class="success-icon">✓</p>
          <h2>Venue submitted</h2>
          <p>Thanks for contributing! We'll review and add it within 2–3 business days.</p>
          <a href="/submit" class="btn btn-secondary" style="margin-top:1.5rem;">Submit another</a>
        </div>
      </div>

      <div class="form-content" id="form-content">
        <div class="trust-bar">
          <div class="trust-item">528+ venues listed</div>
          <div class="trust-sep">·</div>
          <div class="trust-item">Community-powered</div>
          <div class="trust-sep">·</div>
          <div class="trust-item">100% free</div>
        </div>

        <div class="form-wrap">
          <form
            name="venue-submit"
            method="POST"
            data-netlify="true"
            netlify-honeypot="bot-field"
            action="/submit?success=true"
          >
            <input type="hidden" name="form-name" value="venue-submit" />
            <p class="hidden-field"><label>Don't fill this out: <input name="bot-field" /></label></p>

            <div class="form-group">
              <label for="venue-name">Venue name *</label>
              <input type="text" id="venue-name" name="venue-name" placeholder="e.g. Restore Hyper Wellness" required />
            </div>

            <div class="form-row">
              <div class="form-group">
                <label for="city">City *</label>
                <input type="text" id="city" name="city" placeholder="e.g. Austin" required />
              </div>
              <div class="form-group">
                <label for="country">Country *</label>
                <input type="text" id="country" name="country" placeholder="e.g. United States" required />
              </div>
            </div>

            <div class="form-group">
              <label for="address">Address <span class="optional">(optional)</span></label>
              <input type="text" id="address" name="address" placeholder="Full street address" />
            </div>

            <div class="form-group">
              <label for="website">Website <span class="optional">(optional)</span></label>
              <input type="url" id="website" name="website" placeholder="https://..." />
            </div>

            <div class="form-group">
              <label>Modalities * <span class="optional">(select all that apply)</span></label>
              <div class="modality-checkboxes">
                {MODALITY_OPTIONS.map(m => (
                  <label class="checkbox-label">
                    <input type="checkbox" name="modalities" value={m.value} />
                    {m.label}
                  </label>
                ))}
              </div>
            </div>

            <div class="form-group">
              <label for="google-maps">Google Maps link <span class="optional">(optional — helps us verify faster)</span></label>
              <input type="url" id="google-maps" name="google-maps" placeholder="https://maps.google.com/..." />
            </div>

            <div class="form-group">
              <label for="notes">Anything else? <span class="optional">(optional)</span></label>
              <textarea id="notes" name="notes" rows="3" placeholder="Why do you recommend this venue?"></textarea>
            </div>

            <div class="form-group">
              <label for="submitter-email">Your email <span class="optional">(optional — we'll notify you when it's live)</span></label>
              <input type="email" id="submitter-email" name="submitter-email" placeholder="you@email.com" />
            </div>

            <button type="submit" class="btn btn-primary btn-full">Submit venue</button>
          </form>
        </div>

        <div class="bottom-cta">
          <p>Own this venue? <a href="/claim">Claim your listing</a> instead to get full control.</p>
        </div>
      </div>

    </div>
  </section>

  <Footer />
</Layout>

<script>
  const params = new URLSearchParams(window.location.search);
  if (params.get('success') === 'true') {
    const successEl = document.getElementById('success-state');
    const contentEl = document.getElementById('form-content');
    if (successEl) successEl.style.display = 'block';
    if (contentEl) contentEl.style.display = 'none';
  }
</script>

<style>
  .hero {
    padding: 5rem 2rem 4rem;
    text-align: center;
    background: radial-gradient(ellipse at 50% 0%, rgba(6,182,212,0.08) 0%, transparent 65%);
    border-bottom: 1px solid var(--border);
  }
  .hero-content { max-width: 580px; margin: 0 auto; }
  .eyebrow {
    font-size: 11px; font-weight: 700; letter-spacing: 3px;
    text-transform: uppercase; color: var(--accent2); margin-bottom: 1rem;
  }
  .hero-content h1 {
    font-size: 52px;
    background: linear-gradient(135deg, var(--accent2), var(--accent3));
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    background-clip: text; margin-bottom: 1rem;
  }
  .hero-sub { color: var(--muted); font-size: 17px; line-height: 1.6; }

  .section { padding: 3rem 2rem; }
  .container { max-width: 640px; margin: 0 auto; }

  .trust-bar {
    display: flex; align-items: center; justify-content: center;
    gap: 1rem; margin-bottom: 2rem; flex-wrap: wrap;
  }
  .trust-item { font-size: 13px; color: var(--muted); font-weight: 500; }
  .trust-sep { color: var(--border); }

  .success-box {
    text-align: center; padding: 4rem 2rem;
    background: var(--surface); border: 1px solid var(--border); border-radius: 10px;
  }
  .success-icon { font-size: 48px; color: var(--green); margin-bottom: 1rem; }
  .success-box h2 { font-size: 32px; margin-bottom: 0.75rem; color: var(--green); }
  .success-box p { color: var(--muted); font-size: 15px; }

  .form-wrap {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 10px; padding: 2.5rem;
  }

  .hidden-field { display: none; }

  .form-group { margin-bottom: 1.25rem; }
  .form-group label {
    display: block; font-weight: 500; font-size: 13px;
    margin-bottom: 0.4rem; color: var(--text);
  }
  .optional { color: var(--muted); font-weight: 400; }

  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }

  .form-group input[type="text"],
  .form-group input[type="email"],
  .form-group input[type="url"],
  .form-group textarea {
    width: 100%; padding: 10px 12px;
    background: var(--surface2); border: 1px solid var(--border);
    border-radius: 4px; color: var(--text);
    font-family: 'DM Sans', sans-serif; font-size: 14px;
    transition: border-color 0.2s; resize: vertical;
  }
  .form-group input:focus, .form-group textarea:focus {
    outline: none; border-color: var(--accent2);
  }
  .form-group input::placeholder, .form-group textarea::placeholder { color: var(--muted); }

  .modality-checkboxes {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 0.5rem; margin-top: 0.5rem;
  }
  .checkbox-label {
    display: flex; align-items: center; gap: 0.5rem;
    font-size: 13px; color: var(--text); cursor: pointer;
    padding: 6px 10px; border: 1px solid var(--border);
    border-radius: 4px; background: var(--surface2); transition: border-color 0.2s;
  }
  .checkbox-label:hover { border-color: var(--accent2); }
  .checkbox-label input[type="checkbox"] { accent-color: var(--accent2); width: 14px; height: 14px; flex-shrink: 0; }

  .btn {
    display: inline-block; padding: 11px 24px; border-radius: 5px;
    font-weight: 600; font-size: 14px; cursor: pointer;
    text-decoration: none; text-align: center; transition: all 0.18s;
    font-family: 'DM Sans', sans-serif; border: none;
  }
  .btn-primary { background: var(--accent2); color: var(--black); }
  .btn-primary:hover { background: #22d3ee; }
  .btn-secondary { background: transparent; color: var(--text); border: 1px solid var(--border); }
  .btn-secondary:hover { border-color: var(--accent2); color: var(--accent2); }
  .btn-full { width: 100%; }

  .bottom-cta {
    text-align: center; margin-top: 1.5rem;
    font-size: 14px; color: var(--muted);
  }
  .bottom-cta a { color: var(--accent); text-decoration: none; }
  .bottom-cta a:hover { text-decoration: underline; }

  @media (max-width: 640px) {
    .hero { padding: 3rem 1.5rem; }
    .hero-content h1 { font-size: 36px; }
    .section { padding: 2.5rem 1.25rem; }
    .form-wrap { padding: 1.75rem; }
    .form-row { grid-template-columns: 1fr; }
  }
</style>
