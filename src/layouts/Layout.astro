---
interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: string;
}

const {
  title,
  description = "The world's most complete directory of biohacking venues worldwide. Find infrared saunas, cryotherapy, float tanks, IV therapy, TRT clinics and more near you.",
  image = "/og-image.png",
  type = "website"
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, "https://biohackmaps.com").toString();
const ogImage = image.startsWith("http") ? image : `https://biohackmaps.com${image}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — BiohackMaps</title>
    <meta name="description" content={description} />
    
    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL} />
    <meta name="robots" content="index, follow" />
    <meta name="language" content="English" />

    <!-- Favicons -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="BiohackMaps" />
    <meta property="og:title" content={`${title} — BiohackMaps`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={`${title} — BiohackMaps`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:creator" content="@biohackmaps" />
    <meta name="twitter:site" content="@biohackmaps" />
    
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Mono:wght@400;500&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&family=Outfit:wght@900&display=swap"
      rel="stylesheet"
    />

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-YQF2PSNPVS"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-YQF2PSNPVS');
    </script>
    <style is:global>
      :root {
        --black: #080d1a;
        --surface: #0d1424;
        --surface2: #131c30;
        --border: #1e2a42;
        --text: #e8e8e8;
        --muted: #6b7a99;
        --accent: #f97316;
        --accent2: #06b6d4;
        --accent3: #a855f7;
        --green: #22c55e;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        background: var(--black);
        color: var(--text);
        font-family: 'DM Sans', sans-serif;
        font-size: 15px;
        line-height: 1.6;
        overflow-x: hidden;
      }

      h1, h2, h3, h4 {
        font-family: 'Bebas Neue', sans-serif;
        letter-spacing: 1px;
      }

      code, pre {
        font-family: 'DM Mono', monospace;
      }

      @media (max-width: 768px) {
        body {
          font-size: 14px;
        }
      }

      @media (max-width: 480px) {
        body {
          font-size: 13px;
        }
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
